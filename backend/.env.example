# ============================================
# WAREHOUSE SCANNER - BACKEND CONFIGURATION
# ============================================
# Copy this file to ".env" and fill in your values.
# NEVER commit the real .env file to version control.

# --- Server ---
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# --- Database (Supabase Postgres) ---
# Use the TRANSACTION-MODE pooler URL from:
#   Supabase Dashboard → Settings → Database → Connection Pooling
# It looks like: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# --- Google Sheets API ---
# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# The tab/sheet name that holds the parcel data (comma-separated for multiple)
GOOGLE_SHEET_TAB=Sheet1

# Service account credentials. ONE of:
#   - GOOGLE_CREDENTIALS_JSON: the entire service-account JSON as a single line
#     (preferred for serverless / Vercel)
#   - GOOGLE_CREDENTIALS_PATH: path to the JSON file (preferred for local dev)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CREDENTIALS_PATH=./credentials/service-account.json

# --- Authentication ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=12h

# --- Cache ---
# Seconds the sheet data stays cached before refetch
CACHE_TTL_SECONDS=30
