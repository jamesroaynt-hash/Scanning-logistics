# ============================================
# WAREHOUSE SCANNER - BACKEND CONFIGURATION
# ============================================
# Copy this file to ".env" and fill in your values.
# NEVER commit the real .env file to version control.

# --- Server ---
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# --- Google Sheets API ---
# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# The tab/sheet name that holds the parcel data
GOOGLE_SHEET_TAB=Sheet1
# Path to the service account JSON key file (relative to backend root)
GOOGLE_CREDENTIALS_PATH=./credentials/service-account.json

# --- Authentication ---
# Generate a strong random string, e.g. `openssl rand -hex 32`
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=12h

# --- Default Admin Account ---
# Used to bootstrap the first login. Change immediately in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Default Staff Account (optional demo) ---
STAFF_USERNAME=staff
STAFF_PASSWORD=staff123

# --- Cache ---
# Seconds the sheet data stays cached before refetch
CACHE_TTL_SECONDS=30
